generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BetStatus {
  OPEN
  ACCEPTED
  RESULT_PROPOSED
  DISPUTED
  FINALIZED
  CANCELLED
  REFUNDED
}

enum BetSide {
  YES
  NO
}

enum ResolutionMethod {
  API
  WEB_RESEARCH
  AI_EVIDENCE
  MANUAL_REVIEW
}

model UserWallet {
  id        String   @id @default(cuid())
  pubkey    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  makerBets Bet[]     @relation("MakerBets")
  takerBets Bet[]     @relation("TakerBets")
  disputes  Dispute[]
}

model Bet {
  id                  String           @id @default(cuid())
  onChainAddress      String?          @unique
  betIdHash           String           @unique
  originalText        String
  normalizedQuestion  String
  category            String
  yesDefinition       String
  noDefinition        String
  deadlineUtc         DateTime
  resolutionSources   String[]
  resolutionMethod    ResolutionMethod
  objectiveCriteria   String[]
  ambiguityScore      Float
  ambiguityNotes      String[]
  makerSide           BetSide
  stakeLamports       BigInt
  feeBps              Int              @default(100)
  status              BetStatus        @default(OPEN)
  makerFunded         Boolean          @default(false)
  proposedWinner      BetSide?
  finalWinner         BetSide?
  evidenceHash        String?
  disputeDeadlineUtc  DateTime?
  resolverConfidence  Float?
  needsManualReview   Boolean          @default(false)
  resolveAttempts     Int              @default(0)
  lastResolveError    String?
  allowedTaker        String?
  snapshotSource      String?
  snapshotSymbol      String?
  snapshotPrice       Float?
  snapshotTimeUtc     DateTime?

  makerId String
  maker   UserWallet @relation("MakerBets", fields: [makerId], references: [id])

  takerId String?
  taker   UserWallet? @relation("TakerBets", fields: [takerId], references: [id])

  evidence     ResolutionEvidence[]
  disputes     Dispute[]
  transactions Transaction[]
  adminLogs    AdminActionLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, deadlineUtc])        // resolve cron
  @@index([status, disputeDeadlineUtc]) // finalize cron
  @@index([makerId, status])            // active-bets count on create
  @@index([status, createdAt])          // dashboard / bets listing
}

model ResolutionEvidence {
  id                  String   @id @default(cuid())
  betId               String
  bet                 Bet      @relation(fields: [betId], references: [id])
  sourceUrl           String
  sourceName          String
  publishedOrObserved DateTime?
  relevantExcerpt     String
  supports            String
  explanation         String
  createdAt           DateTime @default(now())
}

model Dispute {
  id        String   @id @default(cuid())
  betId     String
  bet       Bet      @relation(fields: [betId], references: [id])
  filedBy   String
  wallet    UserWallet @relation(fields: [filedBy], references: [id])
  reason    String
  createdAt DateTime @default(now())
}

model Transaction {
  id        String   @id @default(cuid())
  betId     String
  bet       Bet      @relation(fields: [betId], references: [id])
  txHash    String
  type      String
  status    String
  createdAt DateTime @default(now())
}

model VipWallet {
  id             String   @id @default(cuid())
  pubkey         String   @unique
  label          String?
  reason         String   @default("manual")
  totalVolumeSol Float    @default(0)
  finalized_bets Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Deprecated: replaced by RateLimitCounter (atomic fixed-window). Kept in the
// schema so `prisma db push` in CI doesn't drop the table (which would need a
// data-loss flag). No longer written to; cleanup cron purges residual rows.
model RateLimitEntry {
  id        String   @id @default(cuid())
  key       String
  createdAt DateTime @default(now())

  @@index([key, createdAt])
}

// Atomic fixed-window rate limit counter. One row per (key, window bucket); the
// count is bumped via a single INSERT ... ON CONFLICT DO UPDATE statement, which
// is race-free under concurrent serverless requests.
model RateLimitCounter {
  key         String
  windowStart DateTime
  count       Int      @default(0)

  @@id([key, windowStart])
  @@index([windowStart])
}

model AdminActionLog {
  id             String   @id @default(cuid())
  betId          String
  bet            Bet      @relation(fields: [betId], references: [id])
  action         String
  adminIdentity  String
  statusBefore   String
  statusAfter    String
  evidenceHash   String?
  details        String?
  createdAt      DateTime @default(now())
}
